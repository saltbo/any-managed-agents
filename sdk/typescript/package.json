{
  "name": "@any-managed-agents/sdk",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "generate": "openapi-ts",
    "smoke": "pnpm run build && node -e \"import('@any-managed-agents/sdk').then((sdk) => { if (typeof sdk.createAmaClient !== 'function') throw new Error('SDK createAmaClient export is missing') })\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.98.2",
    "typescript": "^5.9.3"
  }
}
