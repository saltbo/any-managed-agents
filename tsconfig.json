{
  "files": [],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@ama/runtime-contracts": ["packages/runtime-contracts/src/index.ts"],
      "@ama/runtime-contracts/*": ["packages/runtime-contracts/src/*"],
      "@server/*": ["server/*"],
      "@shared/*": ["shared/*"]
    }
  }
}
