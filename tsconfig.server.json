{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@server/*": ["server/*"],
      "@shared/*": ["shared/*"]
    },
    "types": ["@cloudflare/workers-types", "node"]
  },
  "include": ["server", "e2e", "drizzle.config.ts", "vitest*.ts"],
  "exclude": [
    "server/integration/**/*.test.ts",
    "server/integration/apply-migrations.ts",
    "server/integration/auth.ts"
  ]
}
