AMA_DEFAULT_MODEL=@cf/meta/llama-3.1-8b-instruct

# FlareAuth OIDC client configuration. Configure FlareAuth with this Worker
# callback URL and keep the client secret/session secret in Wrangler secrets.
FLAREAUTH_ISSUER=https://auth.example.com
FLAREAUTH_CLIENT_ID=replace-with-flareauth-client-id
FLAREAUTH_REDIRECT_URI=https://replace-with-worker-host/api/auth/callback
FLAREAUTH_CLIENT_SECRET=replace-with-wrangler-secret
AMA_SESSION_SECRET=replace-with-32-byte-random-secret
AMA_COOKIE_SECURE=true
AMA_COOKIE_SAME_SITE=Lax
AMA_ALLOWED_ORIGINS=https://replace-with-app-host
