AMA_DEFAULT_MODEL=@cf/moonshotai/kimi-k2.6
AMA_RUNTIME_MODE=live
AMA_PI_BRIDGE_PORT=8788

# OIDC client configuration. Configure the provider with this Worker callback URL.
OIDC_ISSUER=https://auth.example.com
OIDC_CLIENT_ID=replace-with-oidc-client-id
OIDC_CLIENT_SECRET=replace-with-wrangler-secret
OIDC_USE_SERVICE_BINDING=true
AMA_SESSION_SECRET=replace-with-32-byte-random-secret
AMA_COOKIE_SECURE=true
AMA_COOKIE_SAME_SITE=Lax
AMA_ALLOWED_ORIGINS=https://replace-with-app-host

# Workers AI is used by the initial Pi runtime path. Store API credentials in
# Wrangler secrets, not in D1 or committed configuration.
AMA_WORKERS_AI_ACCOUNT_ID=replace-with-cloudflare-account-id
AMA_RUNTIME_AI_PROXY_TOKEN=replace-with-wrangler-secret
AMA_AI_GATEWAY_ID=
